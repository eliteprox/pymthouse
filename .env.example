# pymthouse environment configuration

# ---------- App ----------
# Public-facing URL of the app. NextAuth uses this to build OAuth callback
# URLs sent to Google/GitHub (e.g. https://pymthouse.com/api/auth/callback/google).
# In production this must be your actual domain with HTTPS — NOT localhost — or
# OAuth redirects and OIDC device verification URLs will point to http and fail.
# If you set http://pymthouse.com, the app will auto-upgrade to https for
# non-localhost hosts. The registered callback URIs in your Google/GitHub OAuth
# apps must match:
#   {NEXTAUTH_URL}/api/auth/callback/google
#   {NEXTAUTH_URL}/api/auth/callback/github
NEXTAUTH_URL=http://localhost:3001
# When running behind a reverse proxy (e.g. Apache → localhost:3001), set
# NEXTAUTH_URL_INTERNAL so server-side NextAuth calls bypass the proxy and
# go directly to the local Next.js process. Leave unset for local dev.
# NEXTAUTH_URL_INTERNAL=http://localhost:3001
# Generate once and keep stable. Example:
#   openssl rand -base64 32
# If .env.local also sets NEXTAUTH_SECRET, it overrides this value.
NEXTAUTH_SECRET=replace-with-random-base64-secret

# Server-side pepper used by PBKDF2-SHA256 to hash bearer tokens, API keys,
# and OIDC refresh tokens before storage. Must be >=32 chars and kept stable
# for the lifetime of the deployment — changing this value invalidates every
# existing token_hash / key_hash row and requires re-issuing all credentials.
# Generate once:
#   openssl rand -base64 48
AUTH_TOKEN_PEPPER=replace-with-random-base64-pepper

# ---------- OAuth Providers (admin login) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- Database (PostgreSQL; Neon or any libpq URL) ----------
# Required. Migrations run on `npm run dev` / `npm run build` via db:prepare.
# Example (Neon): postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require

# ---------- go-livepeer Remote Signer ----------
# Signer HTTP API URL (host:port). Use configured signer port (default 8081).
# When pymthouse runs on host: http://localhost:8081
# When pymthouse runs in Docker: http://go-livepeer:8081
SIGNER_INTERNAL_URL=http://localhost:8081
# Signer CLI API URL (port 4935). Same port livepeer_cli connects to.
# Bound to 127.0.0.1 in docker-compose — not accessible from the network.
# When pymthouse runs on host: http://localhost:4935
# When pymthouse runs in Docker: http://go-livepeer:4935
SIGNER_CLI_URL=http://localhost:4935
SIGNER_NETWORK=arbitrum-one-mainnet
# Ethereum RPC endpoint for the signer
ETH_RPC_URL=https://arb1.arbitrum.io/rpc

# ---------- Privy (end-user wallets, Phase 4) ----------
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ---------- NaaP Metrics (optional, Phase 5) ----------
# Leave empty to disable metrics reporting
NAAP_METRICS_URL=

# ---------- OIDC ----------
# `npm run oidc:seed` now ensures only the signing key exists.
# Register confidential clients through the app dashboard or API,
# then rotate each client secret from `/api/v1/apps/{clientId}/credentials`.
